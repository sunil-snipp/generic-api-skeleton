{
  "ConnectionStrings": {
    "Database": "Data Source=generic-api.db"
  },
  "Database": {
    "RunMigrationsOnStartup": false
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:O} {Level:u3}] {SourceContext}{NewLine}{Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "OpenApi": {
    "Title": "Generic API",
    "Version": "v1"
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "RateLimiting": {
    "PermitLimit": 200,
    "QueueLimit": 0
  },
  "ExternalIdentity": {
    "BaseUrl": "https://staging-externalidentityapi.snipp.us/",
    "ApiVersion": "1.0",
    "TokenPathTemplate": "/api/v{apiVersion}/ClientAuth/token",
    "ProfilePathTemplate": "/api/v{apiVersion}/ClientAuth/profile",
    "Username": "",
    "Password": ""
  },
  "PowerBi": {
    "TenantId": "",
    "ClientId": "",
    "ClientSecret": "",
    "WorkspaceId": "",
    "ApiBaseUrl": "https://api.powerbi.com/v1.0/myorg"
  },
  "Jwt": {
    "SigningKey": "",
    "Issuer": "Generic.Api",
    "Audience": "Generic.Api"
  },
  "AllowedHosts": "*"
}
